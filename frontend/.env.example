# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
AUTH_SECRET=

# Your production URL (no trailing slash)
AUTH_URL=https://your-app.vercel.app

# Google OAuth — console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Add  https://your-app.vercel.app/api/auth/callback/google  to Authorized redirect URIs
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_TRUST_HOST=true

# ── Backend ────────────────────────────────────────────────────────────────────
# URL of your deployed FastAPI backend (no trailing slash)
NEXT_PUBLIC_BACKEND_HTTP=https://your-backend.example.com
